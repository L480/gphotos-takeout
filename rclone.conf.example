[gdrive]
type = drive
# Use OAuth with your personal Google account.
# Do NOT use a service account for this setup.
scope = drive
# Obtain credentials from Google Cloud Console.
client_id = YOUR_GOOGLE_CLIENT_ID
client_secret = YOUR_GOOGLE_CLIENT_SECRET
# Run `rclone config` locally once, sign in with your personal account,
# and then copy the generated token here.
token = {"access_token":"REPLACE_ME","token_type":"Bearer","refresh_token":"REPLACE_ME","expiry":"2026-01-01T00:00:00Z"}

[ovh-s3-de]
type = s3
provider = Other
env_auth = false
access_key_id = YOUR_OVH_ACCESS_KEY
secret_access_key = YOUR_OVH_SECRET_KEY
region = de
endpoint = s3.de.io.cloud.ovh.net
acl = private
