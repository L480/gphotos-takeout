[gdrive]
type = drive
# Personal Google account OAuth (no service account).
scope = drive
# For personal use you can leave these empty during `rclone config`.
client_id =
client_secret =
# Fill this with the token generated by `rclone config`.
token = {"access_token":"REPLACE_ME","token_type":"Bearer","refresh_token":"REPLACE_ME","expiry":"2026-01-01T00:00:00Z"}

[ovh-s3-de]
type = s3
provider = Other
env_auth = false
access_key_id = YOUR_OVH_ACCESS_KEY
secret_access_key = YOUR_OVH_SECRET_KEY
region = de
endpoint = s3.de.io.cloud.ovh.net
acl = private
